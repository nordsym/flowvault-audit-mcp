  "repository": {
    "type": "git",
    "url": "https://github.com/nordsym/flowvault-audit-mcp"
  },
  "homepage": "https://flowvault.se",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
