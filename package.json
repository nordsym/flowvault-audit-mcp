{
  "name": "@nordsym/flowvault-audit-mcp",
  "version": "0.2.1",
  "private": true,
  "description": "FlowVault Audit MCP - deterministic reliability audit for n8n workflow JSON. Runs locally via Claude Desktop MCP.",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "flowvault-audit-mcp": "dist/server.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p .",
    "dev": "tsx src/server.ts",
    "audit": "tsx src/cli-audit.ts",
    "test": "tsx src/test.ts && tsx src/test-instance.ts",
    "bundle": "bash mcpb/build.sh"
  },
  "keywords": [
    "mcp",
    "n8n",
    "workflow",
    "audit",
    "reliability",
    "flowvault",
    "nordsym"
  ],
